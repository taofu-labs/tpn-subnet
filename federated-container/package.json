{
  "name": "tpn-node",
  "version": "1.9.0",
  "description": "TPN Node docker container code, used for validators, miners, and workers",
  "main": "app.js",
  "type": "module",
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-react": "^7.24.1",
    "@eslint/js": "^9.39.2",
    "airier": "github:actuallymentor/airier#0573a5d213b616789140a31f8dc0464955337788",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "start-server-and-test": "^2.1.3"
  },
  "scripts": {
    "lint": "eslint --fix modules routes app.js",
    "start": "RUN_MODE=oneshot node --env-file-if-exists .env --env-file-if-exists .env.development app.js",
    "start:docker": "docker compose build --build-arg CACHEBUST=$(date +%s) && docker compose up; docker compose down -v",
    "start:validator": "RUN_MODE=validator node --watch --env-file-if-exists .env --env-file-if-exists .env.validator app.js",
    "start:miner": "RUN_MODE=miner node --watch --env-file-if-exists .env --env-file-if-exists .env.miner app.js",
    "start:worker": "RUN_MODE=worker node --watch --env-file-if-exists .env --env-file-if-exists .env.worker app.js",
    "test:validator": "node --test-concurrency=1 --test **/test/*{protocol,validator}*.test.js",
    "test:worker": "node --test-concurrency=1 --test **/test/*worker*.test.js",
    "test:miner": "node --test-concurrency=1 --test **/test/*miner*.test.js",
    "test:watch": "node --test --watch test/*.test.js"
  },
  "dependencies": {
    "@fast-csv/format": "^5.0.5",
    "@maxmind/geoip2-node": "^6.3.4",
    "async-mutex": "^0.5.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "geoip-lite": "^2.0.1",
    "ip2location-nodejs": "^9.7.0",
    "jstat": "^1.9.6",
    "mentie": "^0.5.4",
    "node-pg-format": "^1.3.5",
    "pg": "^8.20.0",
    "pg-format": "^1.0.4",
    "semver": "^7.7.4",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0"
  }
}
